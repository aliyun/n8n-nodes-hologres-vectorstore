{
	"name": "n8n-nodes-hologres-vectorstore",
	"version": "0.1.4",
	"description": "n8n community node for Hologres Vector Store with HGraph index support",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"hologres",
		"vector-store",
		"ai",
		"langchain",
		"rag"
	],
	"license": "Apache-2.0",
	"homepage": "https://github.com/aliyun/n8n-nodes-hologres-vectorstore#readme",
	"author": {
		"name": "TimothyDing"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/aliyun/n8n-nodes-hologres-vectorstore.git"
	},
	"bugs": {
		"url": "https://github.com/aliyun/n8n-nodes-hologres-vectorstore/issues"
	},
	"main": "dist/nodes/VectorStoreHologres/VectorStoreHologres.node.js",
	"scripts": {
		"build": "tsc && gulp build:icons",
		"dev": "tsc --watch",
		"format": "prettier nodes credentials --write",
		"lint": "eslint nodes credentials --ext .ts",
		"lintfix": "eslint nodes credentials --ext .ts --fix",
		"preversion": "npm run lint && npm run build",
		"version": "npm run build && git add -A",
		"prepublishOnly": "npm run build",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage",
		"test:integration": "jest --config jest.integration.config.js",
		"test:all": "npm test && npm run test:integration"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/HologresApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/VectorStoreHologres/VectorStoreHologres.node.js"
		]
	},
	"devDependencies": {
		"@types/jest": "^29.5.12",
		"@types/pg": "^8.11.0",
		"@typescript-eslint/eslint-plugin": "^8.57.1",
		"@typescript-eslint/parser": "^8.57.1",
		"dotenv": "^16.4.5",
		"eslint": "^8.56.0",
		"gulp": "^5.0.1",
		"jest": "^29.7.0",
		"n8n-workflow": "*",
		"prettier": "^3.3.2",
		"ts-jest": "^29.1.2",
		"typescript": "~5.6.0"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"dependencies": {
		"@langchain/core": ">=0.3.0",
		"pg": "^8.13.0"
	}
}
