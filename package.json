{
	"name": "n8n-nodes-hologres-vectorstore",
	"version": "0.1.0",
	"description": "n8n community node for Hologres Vector Store with HGraph index support",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"hologres",
		"vector-store",
		"ai",
		"langchain",
		"rag"
	],
	"license": "MIT",
	"homepage": "",
	"author": {
		"name": "TimothyDing"
	},
	"repository": {
		"type": "git",
		"url": ""
	},
	"main": "index.js",
	"scripts": {
		"build": "tsc && gulp build:icons",
		"dev": "tsc --watch",
		"format": "prettier nodes credentials --write",
		"lint": "eslint nodes credentials package.json",
		"lintfix": "eslint nodes credentials package.json --fix",
		"prepublishOnly": "npm run build"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/HologresApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/VectorStoreHologres/VectorStoreHologres.node.js"
		]
	},
	"devDependencies": {
		"@types/pg": "^8.11.0",
		"@typescript-eslint/parser": "^7.15.0",
		"eslint": "^8.56.0",
		"gulp": "^4.0.2",
		"n8n-workflow": "*",
		"prettier": "^3.3.2",
		"typescript": "~5.6.0"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"dependencies": {
		"@langchain/core": ">=0.3.0",
		"pg": "^8.13.0"
	}
}
