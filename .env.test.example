# Hologres Integration Test Environment Variables
# Copy this file to .env.test and fill in your actual values

# Hologres connection host (e.g., your-instance.hologres.aliyuncs.com)
HOLOGRES_HOST=your-hologres-host.hologres.aliyuncs.com

# Hologres port (default: 80)
HOLOGRES_PORT=80

# Database name
HOLOGRES_DATABASE=test_db

# Database user
HOLOGRES_USER="test_user"

# Database password
HOLOGRES_PASSWORD="your_password"

# SSL connection mode: disable, require, allow-unauthorized
# - disable: No SSL (default, suitable for port 80)
# - require: SSL required
# - allow-unauthorized: SSL with self-signed certificates
HOLOGRES_SSL=disable